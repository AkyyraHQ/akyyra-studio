# Core
NODE_ENV=development
WEB_URL=https://akyyra.com
API_URL=https://api.akyyra.com

# Auth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
JWT_SECRET=your_jwt_secret
COOKIE_SECRET=your_cookie_secret

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/akyyra

# Redis
REDIS_URL=redis://localhost:6379

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# YouTube
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:4000/auth/youtube/callback

# Uploads
UPLOAD_TMP_DIR=./tmp/uploads
UPLOAD_MAX_BYTES_FREE=2147483648
UPLOAD_MAX_BYTES_PRO=5368709120
UPLOAD_CLEANUP_HOURS=24
